#!/usr/bin/env bash
# scripts/pre-commit — Git pre-commit hook
# Validates commit messages follow Conventional Commits format
# Also runs ShellCheck on staged .sh files

set -euo pipefail

# Lint staged shell scripts
STAGED_SH_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sh$' || true)

if [[ -n "$STAGED_SH_FILES" ]]; then
    if command -v shellcheck >/dev/null 2>&1; then
        echo "Running ShellCheck on staged files..."
        echo "$STAGED_SH_FILES" | xargs shellcheck -x
        echo "ShellCheck passed"
    else
        echo "Warning: ShellCheck not installed, skipping lint"
    fi
fi

# Validate commit message format (Conventional Commits)
COMMIT_MSG_FILE="$1"

if [[ -n "${COMMIT_MSG_FILE:-}" && -f "$COMMIT_MSG_FILE" ]]; then
    COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")
    PATTERN='^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\(.+\))?!?:\s.{1,}$'

    if ! [[ "$COMMIT_MSG" =~ $PATTERN ]]; then
        echo "ERROR: Commit message does not follow Conventional Commits format."
        echo ""
        echo "Expected: <type>(<scope>): <description>"
        echo "Example:  feat: add new feature"
        echo "Example:  fix(parser): handle edge case"
        echo ""
        echo "Types: feat, fix, docs, style, refactor, perf, test, chore, build, ci, revert"
        echo ""
        echo "Your message: $COMMIT_MSG"
        exit 1
    fi
fi
